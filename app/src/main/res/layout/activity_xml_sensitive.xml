<?xml version="1.0" encoding="utf-8"?>
<com.hexteam.screenprotect.secureui.SecureFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/secureRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_background">

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:paddingBottom="12dp"
                android:text="@string/back"
                android:textColor="@color/demo_accent"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/xml_title"
                android:textColor="@color/demo_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/status_off"
                android:textColor="@color/demo_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/xml_secret_label"
                android:textColor="@color/demo_accent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/secretText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/demo_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/demo_field_tint"
                android:hint="@string/xml_email_hint"
                android:importantForAutofill="yes"
                android:inputType="textEmailAddress"
                android:textColor="@color/demo_text_primary"
                android:textColorHint="@color/demo_hint" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/demo_field_tint"
                android:hint="@string/xml_password_hint"
                android:importantForAutofill="yes"
                android:inputType="textPassword"
                android:textColor="@color/demo_text_primary"
                android:textColorHint="@color/demo_hint" />

            <EditText
                android:id="@+id/accountInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/demo_field_tint"
                android:hint="@string/xml_account_hint"
                android:inputType="number"
                android:textColor="@color/demo_text_primary"
                android:textColorHint="@color/demo_hint" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/demo_overlay_scrim"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/overlay_title"
            android:textColor="@color/demo_overlay_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/overlay_body"
            android:textColor="@color/demo_overlay_body"
            android:textSize="15sp" />

        <Button
            android:id="@+id/overlayDismissButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/overlay_hide_inline" />
    </LinearLayout>
</com.hexteam.screenprotect.secureui.SecureFrameLayout>
